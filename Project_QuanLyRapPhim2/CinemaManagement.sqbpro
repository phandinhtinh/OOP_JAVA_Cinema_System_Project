-- 3.3. 20 BỘ PHIM
INSERT INTO Phim (Ten_Phim, The_Loai, Thoi_Luong, Ngay_Khoi_Chieu, Mo_Ta, Anh_Bia) VALUES 
('Godzilla x Kong', 'Hành động, Viễn tưởng', 115, '2024-03-29', 'Hai siêu quái vật huyền thoại Godzilla và Kong tạm gác lại ân oán để cùng nhau đối đầu với một mối đe dọa bí ẩn dưới lòng Trái Đất.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/g/o/godzilla_vs_1_.jpg'),
('Avengers: Endgame', 'Hành động, Viễn tưởng', 181, '2019-04-26', 'Trận chiến vĩ đại nhất của vũ trụ điện ảnh Marvel. Các siêu anh hùng còn sống sót hợp lực để đảo ngược cú búng tay của Thanos.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/a/4/a4_160.jpg'),
('Fast &amp; Furious 10', 'Hành động, Đua xe', 141, '2023-05-19', 'Dominic Toretto và gia đình phải đối mặt với một kẻ thù nguy hiểm từ quá khứ, kẻ mang lòng thù hận tột cùng muốn phá hủy tất cả.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/7/0/700x1000-fastx_1.jpg'),
('Spider-Man: No Way Home', 'Hành động, Siêu anh hùng', 148, '2021-12-17', 'Danh tính bị bại lộ, Peter Parker nhờ Doctor Strange giúp đỡ, nhưng vô tình mở ra đa vũ trụ kéo theo vô số ác nhân.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/s/n/snwh_new_fb1080x1350_1_.jpg'),
('Doraemon: Bản giao hưởng', 'Hoạt Hình, Gia Đình', 115, '2024-05-24', 'Nobita và nhóm bạn cùng Doraemon dấn thân vào một cuộc phiêu lưu âm nhạc tuyệt diệu để giải cứu hành tinh khỏi sự im lặng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/d/r/drm24_-_poster.jpg'),
('Kung Fu Panda 4', 'Hoạt Hình, Hài hước', 94, '2024-03-08', 'Po đối mặt với một pháp sư biến hình tàn ác. Cậu phải tìm người kế vị danh hiệu Thần Long Đại Hiệp và bảo vệ Thung Lũng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/4/7/470x700-kungfupanda4.jpg'),
('Inside Out 2', 'Hoạt Hình, Tâm Lý', 100, '2024-06-14', 'Cô bé Riley bước vào tuổi dậy thì, mang theo sự xuất hiện của những cảm xúc mới mẻ và phức tạp, gây đảo lộn thế giới nội tâm.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/1/0/1080x1350-insideout.jpg'),
('Toy Story 4', 'Hoạt Hình, Phiêu lưu', 100, '2019-06-21', 'Woody, Buzz và những người bạn đồ chơi bắt đầu một chuyến dã ngoại, nơi họ gặp gỡ người bạn mới Forky và hiểu thêm về giá trị bản thân.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/p/o/poster_1_2.jpg'),
('Mai', 'Tình cảm, Tâm lý', 131, '2024-02-10', 'Câu chuyện chân thực và cảm động về cuộc đời thăng trầm của Mai, một người phụ nữ khao khát tình yêu nhưng đầy rẫy những tổn thương.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/m/a/mai_teaser_poster_digital_1_.jpg'),
('Titanic', 'Tình cảm, Lãng mạn', 195, '1997-12-19', 'Chuyện tình bi tráng và lãng mạn giữa Jack và Rose trên chuyến tàu định mệnh Titanic trước khi thảm họa chìm tàu xảy ra.', 'https://m.media-amazon.com/images/M/MV5BYzYyN2FiZmUtYWYzMy00MzViLWJkZTMtOGY1ZjgzNWMwN2YxXkEyXkFqcGc@._V1_.jpg'),
('La La Land', 'Tình cảm, Âm nhạc', 128, '2016-12-09', 'Mối tình tuyệt đẹp nhưng dang dở giữa một nhạc công jazz và một nữ diễn viên trẻ giữa lòng Hollywood hoa lệ.', 'https://lionsgate.brightspotcdn.com/ed/5a/ce8dc04443b286bb3e488fd20c01/la-la-land-movie-bg01-portrait.jpg'),
('Lật Mặt 7', 'Gia đình, Tâm lý', 138, '2024-04-26', 'Hành trình đầy cảm xúc của một người mẹ già vất vả cùng những đứa con, khắc họa sâu sắc tình cảm gia đình thiêng liêng.', 'https://www.bhdstar.vn/wp-content/uploads/2024/04/referenceSchemeHeadOfficeallowPlaceHoldertrueheight700ldapp-35.jpg'),
('Exhuma: Quật Mộ', 'Kinh dị, Tâm linh', 134, '2024-02-22', 'Một nhóm pháp sư, thầy phong thủy và nhà thám hiểm cùng nhau khai quật một ngôi mộ bí ẩn, vô tình đánh thức thế lực hắc ám.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/7/0/700x1000_exhuma-min.jpg'),
('The Conjuring', 'Kinh dị, Ma Quỷ', 112, '2013-07-19', 'Dựa trên câu chuyện có thật về vợ chồng nhà ngoại cảm Warren khi họ đến điều tra những hiện tượng siêu nhiên tại một căn nhà hoang vắng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/v/n/vn_cjrlr_insta_vert_main_1638x2048_intl.jpg'),
('IT', 'Kinh dị, Chú hề', 135, '2017-09-08', 'Nhóm bạn nhỏ ở thị trấn Derry phải hợp sức để đối mặt với ác quỷ Pennywise, kẻ chuyên hóa thân thành chú hề để bắt cóc trẻ em.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/i/t/it-2_resize_web_406x600_2.jpg'),
('Annabelle', 'Kinh dị, Búp bê', 99, '2014-10-03', 'Khởi nguồn của búp bê quỷ ám Annabelle, gieo rắc nỗi kinh hoàng cho một đôi vợ chồng trẻ trong chính căn nhà của họ.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/r/s/rsz_annabelle_comes_home_-_vietnam_-_poster_2_2_1.jpg'),
('Home Alone', 'Hài hước, Gia đình', 103, '1990-11-16', 'Cậu bé Kevin bị bỏ lại một mình ở nhà trong kỳ nghỉ Giáng Sinh và phải lập những cái bẫy thông minh để chống lại hai tên trộm.', 'https://motchillk.bot/storage/hinh-anh/o-nha-mot-minh-thumb.jpg'),
('Mr. Bean', 'Hài hước, Vui nhộn', 90, '1997-08-01', 'Tuyển tập những tình huống dở khóc dở cười của Mr. Bean, một người đàn ông vụng về nhưng luôn có những cách giải quyết vấn đề độc lạ.', 'https://upload.wikimedia.org/wikipedia/en/3/37/Bean_movie_poster.jpg'),
('Rush Hour', 'Hành động, Hài hước', 98, '1998-09-18', 'Sự kết hợp hoàn hảo giữa một thám tử Hong Kong nghiêm túc và một cảnh sát Mỹ lắm mồm trong hành trình giải cứu một cô bé bị bắt cóc.', 'https://motchilll.now/wp-content/uploads/2024/12/gio-cao-diem-8987-thumb.webp'),
('Jumanji', 'Hài hước, Phiêu lưu', 119, '1995-12-15', 'Trò chơi cờ bàn ma thuật vô tình đưa những sinh vật hoang dã nguy hiểm vào thế giới thực, buộc người chơi phải hoàn thành ván cờ để kết thúc.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/t/r/tr_ch_i_k_o_th_ng_c_p_2.jpg');

-- 3.4. THÊM ĐÁNH GIÁ (REVIEW)
INSERT INTO DanhGia (Ma_Phim, Ten_Nguoi_Dung, Noi_Dung) VALUES 
(1, 'Tuấn Hành Động', 'Phim xem đã mắt thực sự, kỹ xảo quá đỉnh! 10/10.'),
(1, 'Bé Bi', 'Kong đấm nhau với Godzilla nhìn sợ quá nhưng mà hay.'),
(2, 'Lê Văn Bom Tấn', 'Tôi yêu bạn 3000. Phim quá cảm xúc, xứng đáng là bom tấn thế kỷ!'),
(4, 'Ngô Tạp Nham', 'Đa vũ trụ mở ra xem cuốn thực sự, Tom Holland diễn ngày càng lên tay.'),
(5, 'Mẹ Bỉm', 'Phim Doraemon năm nay dễ thương, nhạc phim cực kỳ bắt tai, rất thích hợp cho cả gia đình đi xem.'),
(7, 'Trần Bé Bi', 'Inside Out 2 diễn tả tâm lý tuổi dậy thì quá chuẩn, xem vừa buồn cười vừa đồng cảm.'),
(9, 'Hoàng Lệ Rơi', 'Phim Mai khóc hết nước mắt, đạo diễn làm phim càng ngày càng chạm tới cảm xúc người xem.'),
(10, 'Vũ Trái Tim', 'Titanic xem đi xem lại chục lần vẫn thấy hay, một kiệt tác sống mãi với thời gian!'),
(13, 'Đinh Hù Dọa', 'Quật mộ xem rùng mình thật sự, âm thanh hình ảnh ám ảnh khủng khiếp. Ai yếu tim cân nhắc nhé.'),
(17, 'Đỗ Tạp Nham', 'Home Alone coi dịp Giáng sinh là chuẩn bài, cười đau cả bụng từ đầu đến cuối.');

