('Phòng 10 - Private', 'VIP', 20);

-- 3.6. TỰ ĐỘNG TẠO GHẾ BẰNG TRUY VẤN ĐỆ QUY (Thay thế vòng lặp WHILE của SQL Server)
INSERT INTO Ghe (Ma_Phong, So_Ghe, Loai_Ghe)
WITH RECURSIVE 
  rooms(p) AS (SELECT 1 UNION ALL SELECT p+1 FROM rooms WHERE p &lt; 10),
  seats(g) AS (SELECT 1 UNION ALL SELECT g+1 FROM seats WHERE g &lt; 30)
SELECT p, 'G' || g, 'Thường' FROM rooms, seats;

-- 3.7. TỰ ĐỘNG TẠO SUẤT CHIẾU BẰNG TRUY VẤN ĐỆ QUY (Thay thế vòng lặp WHILE)
INSERT INTO Suat_Chieu (Ma_Phim, Ma_Phong, Thoi_Gian_Bat_Dau, Gia_Ve)
WITH RECURSIVE seq(i) AS (
    SELECT 1 UNION ALL SELECT i + 1 FROM seq WHERE i &lt; 20
)
SELECT 
    i, 
    ((i - 1) % 10) + 1, 
    datetime('2024-05-01 08:00:00', '+' || i || ' hours'), 
    90000 
FROM seq;

