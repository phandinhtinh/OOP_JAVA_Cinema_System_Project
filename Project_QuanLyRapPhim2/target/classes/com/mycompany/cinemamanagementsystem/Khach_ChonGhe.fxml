<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="khungChinh" alignment="CENTER" prefHeight="700.0" prefWidth="1000.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.cinemamanagementsystem.Khach_ChonGheController">
   <children>
      <Label text="MÀN HÌNH CHỌN GHẾ - ĐẶT VÉ TRỰC TUYẾN" textFill="#cf2b26">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>

      <HBox alignment="CENTER" spacing="15.0">
         <children>
            <Label text="Chọn giờ chiếu:" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <ComboBox fx:id="cbGioChieu" prefWidth="150.0" promptText="-- Chọn Giờ --" />
            
            <Label text="Chọn phòng chiếu:" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
            <ComboBox fx:id="cbPhongChieu" prefWidth="150.0" promptText="-- Chọn Phòng --" />
         </children>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </HBox>

      <Label text="MÀN HÌNH" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="30.0" top="10.0" />
         </VBox.margin>
         <style>-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 100 5 100; -fx-background-radius: 5;</style>
      </Label>

      <GridPane fx:id="gridGhe" alignment="CENTER" hgap="10.0" vgap="10.0">
      </GridPane>
      
      <HBox alignment="CENTER" spacing="20.0">
         <VBox.margin>
            <Insets top="30.0" />
         </VBox.margin>
         <children>
            <Button mnemonicParsing="false" onAction="#quayLaiTrangTruoc" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="&lt; QUAY LẠI">
               <padding>
                  <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
               </padding>
            </Button>
            
            <Button fx:id="btnXacNhan" mnemonicParsing="false" onAction="#xuLyXacNhan" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="XÁC NHẬN CHỌN GHẾ">
               <padding>
                  <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
               </padding>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>