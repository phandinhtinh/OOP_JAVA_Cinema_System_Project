<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="khungChinh" alignment="CENTER" prefHeight="700.0" prefWidth="1000.0" spacing="25.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.cinemamanagementsystem.Khach_ChonDoAnController">
   <children>
      <Label text="CHỌN BẮP NƯỚC (KHÔNG BẮT BUỘC)">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>

      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Label prefWidth="300.0" text="Combo 1 (1 Bắp + 1 Nước ngọt) - 50.000đ">
               <font><Font size="16.0" /></font>
            </Label>
            <Spinner fx:id="spnCombo1" prefWidth="80.0" />
         </children>
      </HBox>

      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Label prefWidth="300.0" text="Combo 2 (1 Bắp + 2 Nước ngọt) - 75.000đ">
               <font><Font size="16.0" /></font>
            </Label>
            <Spinner fx:id="spnCombo2" prefWidth="80.0" />
         </children>
      </HBox>

      <Label fx:id="lblTongTien" text="Tổng tiền bắp nước: 0đ" textFill="#e74c3c">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>

      <HBox alignment="CENTER" spacing="20.0">
         <VBox.margin>
            <Insets top="30.0" />
         </VBox.margin>
         <children>
            <Button mnemonicParsing="false" onAction="#quayLaiTrangTruoc" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="&lt; QUAY LẠI">
               <padding>
                  <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
               </padding>
            </Button>

            <Button mnemonicParsing="false" onAction="#xuLyTiepTuc" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="TIẾP TỤC ĐẾN THANH TOÁN &gt;">
               <padding>
                  <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
               </padding>
            </Button>
         </children>
      </HBox>
      
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
