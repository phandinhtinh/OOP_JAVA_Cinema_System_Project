                            <TableColumn fx:id="colVeSuat" prefWidth="150.0" text="Thời gian chiếu" />
                            <TableColumn fx:id="colVeGhe" prefWidth="70.0" text="Ghế" />
                            <TableColumn fx:id="colVeNgayDat" prefWidth="150.0" text="Ngày đặt" />
                            <TableColumn fx:id="colVeTrangThai" prefWidth="100.0" text="Trạng thái" />
                          </columns>
                        </TableView>
                        <VBox spacing="10.0">
                           <padding>
                              <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
