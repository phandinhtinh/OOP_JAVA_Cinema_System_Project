                                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="829.0" minWidth="10.0" prefWidth="500.0" />
                                </columnConstraints>
                                <rowConstraints>
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                 <children>
                                    <Label text="Mã suất (Đại diện Phim &amp; Giờ):" />
                                    <Label text="Ghế:" GridPane.rowIndex="1" />
                                    <Label text="Ngày đặt (YYYY-MM-DD):" GridPane.rowIndex="2" />
                                    <Label text="Trạng thái:" GridPane.rowIndex="3" />
                                    <TextField fx:id="txtVeMaSuat" maxWidth="300.0" GridPane.columnIndex="1" />
                                    <TextField fx:id="txtVeMaGhe" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    <TextField fx:id="txtVeNgayDat" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    <TextField fx:id="txtVeTrangThai" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                 </children>
                              </GridPane>
                              <HBox alignment="CENTER" spacing="15.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#themVe" prefWidth="80.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Thêm" />
                                    <Button mnemonicParsing="false" onAction="#suaVe" prefWidth="80.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Sửa" />
                                    <Button mnemonicParsing="false" onAction="#xoaVe" prefWidth="80.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Xoá" />
                                 </children>
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <VBox fx:id="paneThongKe" style="-fx-background-color: rgba(255, 255, 255, 0.9);" visible="false">
                     <children>
                        <TableView fx:id="tvThongKe" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colTKPhim" prefWidth="300.0" text="Tên phim" />
                            <TableColumn fx:id="colTKSoVe" prefWidth="150.0" text="Số vé đã bán" />
                            <TableColumn fx:id="colTKDoanhThu" prefWidth="200.0" text="Tổng doanh thu" />
                          </columns>
                        </TableView>
                        
                        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
                            <padding>
                               <Insets bottom="10.0" left="20.0" right="30.0" top="10.0" />
                            </padding>
                            <children>
                               <Label text="TỔNG DOANH THU:" textFill="#2c3e50" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                               <Label fx:id="lblTongDoanhThu" text="0 VNĐ" textFill="#e74c3c" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                            </children>
                        </HBox>
                     </children>
                  </VBox>
                  
               </children>
