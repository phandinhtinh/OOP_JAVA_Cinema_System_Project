                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                 <children>
                                    <Label text="Mã phim:" />
                                    <Label text="Mã phòng:" GridPane.rowIndex="1" />
                                    <Label text="Thời gian (YYYY-MM-DD HH:MM):" GridPane.rowIndex="2" />
                                    <Label text="Giá vé:" GridPane.rowIndex="3" />
                                    <TextField fx:id="txtSCMaPhim" maxWidth="300.0" GridPane.columnIndex="1" />
                                    <TextField fx:id="txtSCMaPhong" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    <TextField fx:id="txtSCThoiGian" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    <TextField fx:id="txtSCGiaVe" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                 </children>
                              </GridPane>
                              <HBox alignment="CENTER" spacing="15.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#themSuatChieu" prefWidth="80.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Thêm" />
                                    <Button mnemonicParsing="false" onAction="#suaSuatChieu" prefWidth="80.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Sửa" />
                                    <Button mnemonicParsing="false" onAction="#xoaSuatChieu" prefWidth="80.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Xoá" />
                                 </children>
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <VBox fx:id="paneBanVe" style="-fx-background-color: rgba(255, 255, 255, 0.9);" visible="false">
                     <children>
                        <TableView fx:id="tvBanVe" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colVeMaVe" prefWidth="70.0" text="Mã vé" />
