-- Dùng truy vấn đệ quy của SQLite để tạo ra 300 ghế siêu nhanh
INSERT INTO Ghe (Ma_Phong, So_Ghe, Loai_Ghe) 
WITH RECURSIVE
  phong(p) AS (SELECT 1 UNION ALL SELECT p+1 FROM phong WHERE p &lt; 10),
  ghe(g) AS (SELECT 1 UNION ALL SELECT g+1 FROM ghe WHERE g &lt; 30)
SELECT p, 'G' || g, 'Thường' FROM phong, ghe;

-- Tạo 50 suất chiếu tự động
INSERT INTO Suat_Chieu (Ma_Phim, Ma_Phong, Thoi_Gian_Bat_Dau, Gia_Ve) 
WITH RECURSIVE
  phim(i) AS (SELECT 1 UNION ALL SELECT i+1 FROM phim WHERE i &lt; 50)
SELECT i, (i % 10) + 1, datetime('2024-05-01 08:00:00', '+' || i || ' hours'), 90000 FROM phim;

