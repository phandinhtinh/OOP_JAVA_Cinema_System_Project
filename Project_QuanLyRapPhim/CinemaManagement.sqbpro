<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="CinemaManagement.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3364"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Ghe" custom_title="0" dock_id="1" table="4,3:mainGhe"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011300ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- Kích hoạt khóa ngoại trong SQLite
PRAGMA foreign_keys = ON;

-- 1. XÓA BẢNG CŨ (Nếu có)
DROP TABLE IF EXISTS DanhGia;
DROP TABLE IF EXISTS Phim_TheLoai;
DROP TABLE IF EXISTS Phim_DienVien;
DROP TABLE IF EXISTS Phim_DaoDien;
DROP TABLE IF EXISTS Trang_Thai_Ghe;
DROP TABLE IF EXISTS Lich_Su_Thanh_Toan;
DROP TABLE IF EXISTS Chi_Tiet_Hoa_Don_SP;
DROP TABLE IF EXISTS Ve;
DROP TABLE IF EXISTS Hoa_Don;
DROP TABLE IF EXISTS San_Pham;
DROP TABLE IF EXISTS Khuyen_Mai;
DROP TABLE IF EXISTS Dao_Dien;
DROP TABLE IF EXISTS Dien_Vien;
DROP TABLE IF EXISTS The_Loai;
DROP TABLE IF EXISTS Ghe;
DROP TABLE IF EXISTS Suat_Chieu;
DROP TABLE IF EXISTS Khach_Hang;
DROP TABLE IF EXISTS Phong_Chieu;
DROP TABLE IF EXISTS Phim;
DROP TABLE IF EXISTS Nhan_Vien;

-- 2. TẠO CẤU TRÚC BẢNG (Chuẩn SQLite)
CREATE TABLE Nhan_Vien (
    Ma_NV INTEGER PRIMARY KEY AUTOINCREMENT,
    Ho_Ten TEXT NOT NULL,
    Ngay_Sinh DATE,
    SDT TEXT,
    Ten_Dang_Nhap TEXT UNIQUE NOT NULL,
    Mat_Khau TEXT NOT NULL, 
    Vai_Tro TEXT DEFAULT 'Nhân viên'
);

CREATE TABLE Khach_Hang (
    Ma_KH INTEGER PRIMARY KEY AUTOINCREMENT,
    Ho_Ten TEXT NOT NULL,
    Ngay_Sinh DATE,
    Ten_Dang_Nhap TEXT UNIQUE NOT NULL, 
    Mat_Khau TEXT NOT NULL,            
    SDT TEXT UNIQUE,
    Email TEXT,
    Diem_Tich_Luy INTEGER DEFAULT 0
);

CREATE TABLE The_Loai (
    Ma_The_Loai INTEGER PRIMARY KEY AUTOINCREMENT,
    Ten_The_Loai TEXT NOT NULL
);

CREATE TABLE Dien_Vien (
    Ma_Dien_Vien INTEGER PRIMARY KEY AUTOINCREMENT,
    Ten_Dien_Vien TEXT NOT NULL,
    Anh_Dien_Vien TEXT
);

CREATE TABLE Dao_Dien (
    Ma_Dao_Dien INTEGER PRIMARY KEY AUTOINCREMENT,
    Ten_Dao_Dien TEXT NOT NULL,
    Anh_Dao_Dien TEXT
);

CREATE TABLE Khuyen_Mai (
    Ma_Khuyen_Mai INTEGER PRIMARY KEY AUTOINCREMENT,
    Loai_Giam_Gia TEXT,
    Gia_Tri_Giam REAL,
    Giam_Toi_Da REAL,
    Don_Tien_Toi_Thieu REAL,
    So_Luong_Toi_Da INTEGER,
    Ngay_Bat_Dau DATE,
    Ngay_Ket_Thuc DATE
);

CREATE TABLE San_Pham (
    Ma_San_Pham INTEGER PRIMARY KEY AUTOINCREMENT,
    Ten_San_Pham TEXT NOT NULL,
    Don_Gia REAL NOT NULL
);

CREATE TABLE Phim (
    Ma_Phim INTEGER PRIMARY KEY AUTOINCREMENT,
    Ten_Phim TEXT NOT NULL,
    The_Loai TEXT, 
    Thoi_Luong INTEGER,
    Ngay_Khoi_Chieu DATE,
    Ngon_Ngu TEXT,
    Trailer TEXT,
    Rated TEXT,
    Mo_Ta TEXT,
    Anh_Bia TEXT 
);

CREATE TABLE DanhGia (
    Ma_DanhGia INTEGER PRIMARY KEY AUTOINCREMENT,
    Ma_Phim INTEGER,
    Ten_Nguoi_Dung TEXT,
    Noi_Dung TEXT NOT NULL,
    Ngay_Danh_Gia DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (Ma_Phim) REFERENCES Phim(Ma_Phim) ON DELETE CASCADE
);

CREATE TABLE Phim_TheLoai (
    Ma_Phim INTEGER,
    Ma_The_Loai INTEGER,
    PRIMARY KEY (Ma_Phim, Ma_The_Loai),
    FOREIGN KEY (Ma_Phim) REFERENCES Phim(Ma_Phim),
    FOREIGN KEY (Ma_The_Loai) REFERENCES The_Loai(Ma_The_Loai)
);

CREATE TABLE Phim_DienVien (
    Ma_Phim INTEGER,
    Ma_Dien_Vien INTEGER,
    PRIMARY KEY (Ma_Phim, Ma_Dien_Vien),
    FOREIGN KEY (Ma_Phim) REFERENCES Phim(Ma_Phim),
    FOREIGN KEY (Ma_Dien_Vien) REFERENCES Dien_Vien(Ma_Dien_Vien)
);

CREATE TABLE Phim_DaoDien (
    Ma_Phim INTEGER,
    Ma_Dao_Dien INTEGER,
    PRIMARY KEY (Ma_Phim, Ma_Dao_Dien),
    FOREIGN KEY (Ma_Phim) REFERENCES Phim(Ma_Phim),
    FOREIGN KEY (Ma_Dao_Dien) REFERENCES Dao_Dien(Ma_Dao_Dien)
);

CREATE TABLE Phong_Chieu (
    Ma_Phong INTEGER PRIMARY KEY AUTOINCREMENT,
    Ten_Phong TEXT NOT NULL,
    Loai_Phong TEXT DEFAULT 'Tiêu chuẩn',
    Tong_So_Ghe INTEGER DEFAULT 0
);

CREATE TABLE Ghe (
    Ma_Ghe INTEGER PRIMARY KEY AUTOINCREMENT,
    Ma_Phong INTEGER,
    So_Ghe TEXT NOT NULL, 
    Loai_Ghe TEXT DEFAULT 'Thường',
    FOREIGN KEY (Ma_Phong) REFERENCES Phong_Chieu(Ma_Phong) ON DELETE CASCADE
);

CREATE TABLE Suat_Chieu (
    Ma_Suat INTEGER PRIMARY KEY AUTOINCREMENT,
    Ma_Phim INTEGER,
    Ma_Phong INTEGER,
    Thoi_Gian_Bat_Dau DATETIME NOT NULL,
    Dinh_Dang_Phim TEXT,
    Ngon_Ngu TEXT,
    Gia_Ve REAL NOT NULL,
    FOREIGN KEY (Ma_Phim) REFERENCES Phim(Ma_Phim) ON DELETE CASCADE,
    FOREIGN KEY (Ma_Phong) REFERENCES Phong_Chieu(Ma_Phong) ON DELETE CASCADE
);

CREATE TABLE Trang_Thai_Ghe (
    Ma_Suat INTEGER,
    Ma_Ghe INTEGER,
    Trang_Thai TEXT, 
    PRIMARY KEY (Ma_Suat, Ma_Ghe),
    FOREIGN KEY (Ma_Suat) REFERENCES Suat_Chieu(Ma_Suat),
    FOREIGN KEY (Ma_Ghe) REFERENCES Ghe(Ma_Ghe)
);

CREATE TABLE Hoa_Don (
    Ma_Hoa_Don INTEGER PRIMARY KEY AUTOINCREMENT,
    Ngay_Lap DATETIME DEFAULT CURRENT_TIMESTAMP,
    Ma_KH INTEGER,
    Ma_NV INTEGER,
    Ma_Khuyen_Mai INTEGER,
    FOREIGN KEY (Ma_KH) REFERENCES Khach_Hang(Ma_KH),
    FOREIGN KEY (Ma_NV) REFERENCES Nhan_Vien(Ma_NV),
    FOREIGN KEY (Ma_Khuyen_Mai) REFERENCES Khuyen_Mai(Ma_Khuyen_Mai)
);

CREATE TABLE Ve (
    Ma_Ve INTEGER PRIMARY KEY AUTOINCREMENT,
    Ma_Suat INTEGER,
    Ma_KH INTEGER,
    Ma_NV INTEGER,
    Ma_Ghe INTEGER,
    Ma_Hoa_Don INTEGER,
    Thoi_Gian_Dat DATETIME DEFAULT CURRENT_TIMESTAMP,
    Trang_Thai TEXT DEFAULT 'Đã thanh toán',
    FOREIGN KEY (Ma_Suat) REFERENCES Suat_Chieu(Ma_Suat),
    FOREIGN KEY (Ma_KH) REFERENCES Khach_Hang(Ma_KH),
    FOREIGN KEY (Ma_NV) REFERENCES Nhan_Vien(Ma_NV),
    FOREIGN KEY (Ma_Ghe) REFERENCES Ghe(Ma_Ghe),
    FOREIGN KEY (Ma_Hoa_Don) REFERENCES Hoa_Don(Ma_Hoa_Don)
);

CREATE TABLE Chi_Tiet_Hoa_Don_SP (
    Ma_Hoa_Don INTEGER,
    Ma_San_Pham INTEGER,
    So_Luong INTEGER NOT NULL,
    Thanh_Tien REAL NOT NULL,
    PRIMARY KEY (Ma_Hoa_Don, Ma_San_Pham),
    FOREIGN KEY (Ma_Hoa_Don) REFERENCES Hoa_Don(Ma_Hoa_Don),
    FOREIGN KEY (Ma_San_Pham) REFERENCES San_Pham(Ma_San_Pham)
);

CREATE TABLE Lich_Su_Thanh_Toan (
    Ma_Thanh_Toan INTEGER PRIMARY KEY AUTOINCREMENT,
    Ma_Hoa_Don INTEGER,
    Phuong_Thuc TEXT,
    So_Tien REAL NOT NULL,
    Trang_Thai TEXT,
    Thoi_Gian DATETIME DEFAULT CURRENT_TIMESTAMP,
    Ghi_Chu TEXT,
    FOREIGN KEY (Ma_Hoa_Don) REFERENCES Hoa_Don(Ma_Hoa_Don)
);

-- =========================================================================
-- 3. NẠP DỮ LIỆU MẪU 
-- =========================================================================

