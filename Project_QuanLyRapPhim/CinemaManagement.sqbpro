INSERT INTO Phim (Ten_Phim, The_Loai, Thoi_Luong, Ngay_Khoi_Chieu, Mo_Ta, Anh_Bia) VALUES 
('Godzilla x Kong', 'Hành động, Viễn tưởng', 115, '2024-03-29', 'Hai siêu quái vật Godzilla và Kong đụng độ trong một trận chiến lịch sử để đối phó với một mối đe dọa hủy diệt mới.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/g/o/godzilla_vs_1_.jpg'),
('Avengers: Endgame', 'Hành động, Viễn tưởng', 181, '2019-04-26', 'Trận chiến cuối cùng bi tráng của biệt đội siêu anh hùng Avengers nhằm đảo ngược cú búng tay của Thanos và cứu lấy vũ trụ.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/a/4/a4_160.jpg'),
('Fast &amp; Furious 10', 'Hành động, Đua xe', 141, '2023-05-19', 'Dom Toretto và gia đình đối mặt với Dante, kẻ thù nguy hiểm nhất từ trước đến nay, mang theo âm mưu trả thù tàn độc.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/7/0/700x1000-fastx_1.jpg'),
('Spider-Man: No Way Home', 'Hành động, Siêu anh hùng', 148, '2021-12-17', 'Peter Parker nhờ Doctor Strange giúp đỡ để xóa ký ức mọi người, vô tình mở ra cánh cửa kết nối các đa vũ trụ khác nhau.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/s/n/snwh_new_fb1080x1350_1_.jpg'),
('Mission: Impossible 7', 'Hành động, Điệp viên', 163, '2023-07-12', 'Ethan Hunt và nhóm IMF thực hiện nhiệm vụ nguy hiểm nhất: truy lùng một vũ khí đáng sợ trước khi nó rơi vào tay kẻ xấu.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/m/i/mi8_poster_470x700_1.jpg'),
('The Matrix Resurrections', 'Hành động, Viễn tưởng', 148, '2021-12-22', 'Neo một lần nữa phải lựa chọn uống viên thuốc đỏ để quay lại Ma Trận và giải cứu người tình Trinity.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/3/image/c5f0a1eff4c394a251036189ccddaacd/p/o/poster_matrix_4_1_.jpg'),
('Transformers: Rise of the Beasts', 'Hành động, Robot', 127, '2023-06-09', 'Cuộc chiến giữa các phe phái Robot biến hình khổng lồ trên Trái Đất bước sang một kỷ nguyên mới đầy khốc liệt.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/7/0/700x1000_.jpg'),
('John Wick: Chapter 3', 'Hành động, Sát thủ', 169, '2019-05-17', 'Sát thủ John Wick bị truy nã toàn cầu với mức tiền thưởng khổng lồ, buộc anh phải tìm mọi cách để sinh tồn.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/3/image/c5f0a1eff4c394a251036189ccddaacd/j/o/john-wick_3-poster_2.jpg'),
('Mad Max: Fury Road', 'Hành động, Đua xe', 120, '2015-05-15', 'Cuộc tẩu thoát ngoạn mục trên sa mạc thời hậu tận thế của Max và Furiosa khỏi tay tên độc tài bạo chúa.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/3/image/c5f0a1eff4c394a251036189ccddaacd/m/m/mm4fr_bnr_v_dd_ka_tt_2000x3000_300dpi_vn.jpg'),
('Terminator: Dark Fate', 'Hành động, Viễn tưởng', 128, '2019-11-01', 'Kẻ hủy diệt siêu việt từ tương lai xuất hiện, đe dọa sự sống còn của cô gái nắm giữ vận mệnh nhân loại.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/t/e/terminatordarkfate_poster_campb_vie.jpg'),
('Jurassic World', 'Hành động, Khủng long', 124, '2015-06-12', 'Công viên kỷ Jura mở cửa trở lại nhưng một thảm họa mới lại bắt đầu khi loài khủng long lai tạo xổng chuồng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/j/w/jw4_sjquetzart_470x700.jpg'),
('Avatar: The Way of Water', 'Hành động, Viễn tưởng', 192, '2022-12-16', 'Gia đình Jake Sully phải di cư đến vùng đại dương của Pandora và tiếp tục chiến đấu bảo vệ hành tinh.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/c/g/cgv_350x495_1.jpg'),
('Inception', 'Hành động, Viễn tưởng', 148, '2010-07-16', 'Một siêu trộm có khả năng đi vào giấc mơ của người khác để đánh cắp bí mật, nay phải thực hiện một phi vụ cấy ghép ý tưởng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/i/n/inception.jpg'),
('Die Hard', 'Hành động, Tội phạm', 132, '1988-07-15', 'Viên cảnh sát New York ngoan cường một mình chiến đấu chống lại băng nhóm khủng bố đang bắt giữ con tin.', 'https://lh5.googleusercontent.com/-oREXniqeHzs/VS_ewrPjkII/AAAAAAAABhQ/2u394JhZDXI/w300/phimletv-Die-Hard-1988.jpg'),
('Gladiator', 'Hành động, Cổ trang', 155, '2000-05-05', 'Hành trình trả thù đẫm máu của một vị tướng La Mã bị phản bội, nay trở thành võ sĩ giác đấu vĩ đại nhất.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/7/0/700x1000-gladiator.jpg'),
('Doraemon: Bản giao hưởng', 'Hoạt Hình, Gia Đình', 115, '2024-05-24', 'Doraemon, Nobita và những người bạn bước vào cuộc phiêu lưu đến một hành tinh sử dụng âm nhạc làm năng lượng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/d/r/drm24_-_poster.jpg'),
('Kung Fu Panda 4', 'Hoạt Hình, Hài hước', 94, '2024-03-08', 'Gấu Po đối mặt với Tắc Kè Hoa - một kẻ thù nguy hiểm có khả năng sao chép mọi loại võ công của các cao thủ.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/4/7/470x700-kungfupanda4.jpg'),
('Inside Out 2', 'Hoạt Hình, Tâm Lý', 100, '2024-06-14', 'Cô bé Riley bước vào tuổi dậy thì, kéo theo sự xuất hiện của những cảm xúc mới đầy phức tạp như Lo Âu, Ghen Tị.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/1/0/1080x1350-insideout.jpg'),
('Toy Story 4', 'Hoạt Hình, Phiêu lưu', 100, '2019-06-21', 'Cảnh sát vũ trụ Buzz và anh chàng cao bồi Woody bắt đầu một chuyến hành trình mới để tìm ý nghĩa thực sự của một món đồ chơi.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/p/o/poster_1_2.jpg'),
('Frozen 2', 'Hoạt Hình, Âm nhạc', 103, '2019-11-22', 'Elsa, Anna cùng nhóm bạn tiến vào khu rừng phép thuật để khám phá nguồn gốc thực sự về sức mạnh băng giá của nữ hoàng.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/p/o/poster_frozen_nhbg_-final_1_.jpg'),
('Minions: The Rise of Gru', 'Hoạt Hình, Hài hước', 87, '2022-07-01', 'Câu chuyện dở khóc dở cười về tuổi thơ của ác nhân Gru cùng với bầy Minions siêu quậy nhí nhố.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/m/i/minions_2_-_kc_01.7.22_1_.jpg'),
('Shrek', 'Hoạt Hình, Hài hước', 90, '2001-05-18', 'Gã chằn tinh xanh Shrek cau có và chú lừa lắm mồm bắt đầu chuyến hành trình đi cứu nàng công chúa Fiona.', 'https://encrypted-tbn1.gstatic.com/images?q=tbn:ANd9GcTG_q0A0cypAsXxYlgs5J_554BrcnjeeKExlQE3ZaZUuPYv0fUd'),
('Finding Nemo', 'Hoạt Hình, Phiêu lưu', 100, '2003-05-30', 'Hành trình đầy gian nan và thú vị của cá hề Marlin băng qua đại dương mênh mông để tìm lại cậu con trai Nemo.', 'https://resizing.flixster.com/MDACZCFqGbbEZKIundel0l1_QU8=/206x305/v2/https://resizing.flixster.com/-XZAfHZM39UwaGJIFWKAE8fS0ak=/v3/t/assets/p31890_p_v10_bb.jpg'),
('Zootopia', 'Hoạt Hình, Động vật', 108, '2016-03-04', 'Cô thỏ cảnh sát nhiệt huyết Judy và chú cáo tinh ranh Nick cùng nhau phá vụ án bí ẩn tại thành phố của các loài động vật.', 'https://encrypted-tbn2.gstatic.com/images?q=tbn:ANd9GcQVT4BBbKZ5RYJ71XQD0yKS3oPqu11TxA93nXvVcg0oKMeSqdLh'),
('Coco', 'Hoạt Hình, Gia Đình', 105, '2017-11-22', 'Cậu bé Miguel với niềm đam mê âm nhạc vô tình du hành vào Vùng đất Linh hồn và khám phá ra bí mật của gia đình mình.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/c/o/coco-350x495_2.jpg'),
('Mai', 'Tình cảm, Tâm lý', 131, '2024-02-10', 'Câu chuyện tình yêu đầy thăng trầm và xúc động của Mai - một người phụ nữ mang nhiều góc khuất trong cuộc sống.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/m/a/mai_teaser_poster_digital_1_.jpg'),
('Titanic', 'Tình cảm, Lãng mạn', 195, '1997-12-19', 'Mối tình vô cùng lãng mạn nhưng bi thương của Jack và Rose trên chuyến tàu Titanic định mệnh.', 'https://upload.wikimedia.org/wikipedia/en/1/18/Titanic_%281997_film%29_poster.png'),
('La La Land', 'Tình cảm, Âm nhạc', 128, '2016-12-09', 'Bản nhạc tình yêu tuyệt đẹp nhưng dang dở của một chàng nhạc sĩ jazz và một cô nữ diễn viên tham vọng tại Hollywood.', 'https://upload.wikimedia.org/wikipedia/en/a/ab/La_La_Land_%28film%29.png'),
('Your Name', 'Tình cảm, Hoạt Hình', 106, '2016-08-26', 'Hai người trẻ xa lạ bất ngờ bị hoán đổi thể xác, cùng nhau tìm cách vượt qua không gian và thời gian để ngăn chặn thảm họa.', 'https://cdn.galaxycine.vn/media/y/o/yourname.jpg'),
('Lật Mặt 7', 'Gia đình, Tâm lý', 138, '2024-04-26', 'Một bộ phim xoáy sâu vào tâm lý gia đình Việt Nam, những rạn nứt thế hệ và sức mạnh của tình mẫu tử.', 'https://www.bhdstar.vn/wp-content/uploads/2024/04/referenceSchemeHeadOfficeallowPlaceHoldertrueheight700ldapp-35.jpg'),
('The Notebook', 'Tình cảm, Lãng mạn', 123, '2004-06-25', 'Chuyện tình khắc cốt ghi tâm vượt qua mọi định kiến xã hội, được lưu giữ lại trong một cuốn sổ tay cũ kỹ.', 'https://images.moviesanywhere.com/3f8a2408122a35b5aa92727c1909db86/b0cf1ba3-0535-41e1-8713-fad6f87e245d.webp?h=375&amp;resize=fit&amp;w=250'),
('Me Before You', 'Tình cảm, Lãng mạn', 110, '2016-06-03', 'Cô gái nhà quê lạc quan, tươi sáng đã đến và sưởi ấm trái tim đang chết dần của một chàng trai tỷ phú bị liệt toàn thân.', 'https://m.media-amazon.com/images/M/MV5BMTQ2NjE4NDE2NV5BMl5BanBnXkFtZTgwOTcwNDE5NzE@._V1_FMjpg_UX1000_.jpg'),
('A Star is Born', 'Tình cảm, Âm nhạc', 136, '2018-10-05', 'Chàng ca sĩ nhạc đồng quê dần đánh mất hào quang đã giúp một tài năng trẻ vô danh tỏa sáng rực rỡ trên sân khấu.', 'https://i5.walmartimages.com/seo/A-Star-Is-Born-Blu-ray-DVD-Walmart-Exclusive_4e939655-6b40-43a4-b70b-765c072b5d34.54d6381b52effdac0b4fc31482c443cc.jpeg'),
('Forrest Gump', 'Tình cảm, Lãng mạn', 142, '1994-07-06', 'Cuộc đời phi thường của chàng ngốc Forrest Gump qua các biến cố lịch sử, luôn mang trong tim một tình yêu chân thành.', 'https://m.media-amazon.com/images/M/MV5BNDYwNzVjMTItZmU5YS00YjQ5LTljYjgtMjY2NDVmYWMyNWFmXkEyXkFqcGc@._V1_FMjpg_UX1000_.jpg'),
('Parasite', 'Tâm lý, Giật gân', 132, '2019-05-30', 'Sự khác biệt giai cấp khủng khiếp dẫn đến một bi kịch không ai lường trước được giữa hai gia đình tại Hàn Quốc.', 'https://upload.wikimedia.org/wikipedia/en/5/53/Parasite_%282019_film%29.png'),
('Exhuma: Quật Mộ', 'Kinh dị, Tâm linh', 134, '2024-02-22', 'Nhóm thầy pháp và phong thủy sư khai quật một ngôi mộ cổ, vô tình giải phóng một thế lực tà ác đáng sợ.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/7/0/700x1000_exhuma-min.jpg'),
('The Conjuring', 'Kinh dị, Ma Quỷ', 112, '2013-07-19', 'Vợ chồng nhà điều tra ngoại cảm Ed và Lorraine Warren đối mặt với quỷ dữ để cứu một gia đình khỏi sự quấy nhiễu.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/v/n/vn_cjrlr_insta_vert_main_1638x2048_intl.jpg'),
('IT', 'Kinh dị, Chú hề', 135, '2017-09-08', 'Nhóm những đứa trẻ kém cỏi tại thị trấn Derry phải liên kết lại để chiến đấu với chú hề ma quái ăn thịt người Pennywise.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/i/t/it-2_resize_web_406x600_2.jpg'),
('Annabelle', 'Kinh dị, Búp bê', 99, '2014-10-03', 'Con búp bê bị ma ám Annabelle gieo rắc nỗi kinh hoàng tột độ cho một cặp vợ chồng trẻ trong chính ngôi nhà của họ.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/r/s/rsz_annabelle_comes_home_-_vietnam_-_poster_2_2_1.jpg'),
('The Nun', 'Kinh dị, Tâm linh', 96, '2018-09-07', 'Khám phá cội nguồn ác quỷ của ma sơ Valak tại một tu viện hẻo lánh và u ám ở đất nước Romania.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/t/h/the_nun_-_vn_poster_160.jpg'),
('Get Out', 'Kinh dị, Tâm lý', 104, '2017-02-24', 'Một chàng trai da đen phát hiện ra những bí mật kinh hoàng và bệnh hoạn khi đến thăm nhà bố mẹ cô bạn gái da trắng.', 'https://upload.wikimedia.org/wikipedia/en/thumb/a/a3/Get_Out_poster.png/250px-Get_Out_poster.png'),
('A Quiet Place', 'Kinh dị, Viễn tưởng', 90, '2018-04-06', 'Một gia đình buộc phải giao tiếp bằng ngôn ngữ ký hiệu và sống trong im lặng tuyệt đối để trốn tránh loài quái vật khát máu.', 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRsigOtMMr-CIUFeRnEs4Cxhx3-xhW8qEC7YQ&amp;s'),
('Saw', 'Kinh dị, Giật gân', 103, '2004-10-29', 'Những nạn nhân bị bắt cóc phải trải qua các trò chơi sinh tử tàn bạo của tên sát nhân hàng loạt bệnh hoạn Jigsaw.', 'https://resizing.flixster.com/-XZAfHZM39UwaGJIFWKAE8fS0ak=/v3/t/assets/p34813_v_v8_al.jpg'),
('The Ring', 'Kinh dị, Tâm linh', 115, '2002-10-18', 'Lời nguyền khủng khiếp từ một cuộn băng video bí ẩn sẽ giết chết bất cứ ai xem nó đúng 7 ngày sau đó.', 'https://upload.wikimedia.org/wikipedia/vi/thumb/4/4e/The_ring_poster2.jpg/250px-The_ring_poster2.jpg'),
('Insidious', 'Kinh dị, Ma Quỷ', 103, '2010-09-14', 'Gia đình Lambert chiến đấu tuyệt vọng với các linh hồn quỷ dữ từ cõi âm để kéo linh hồn cậu con trai trở về.', 'https://upload.wikimedia.org/wikipedia/en/2/2d/Insidious_poster.jpg'),
('Home Alone', 'Hài hước, Gia đình', 103, '1990-11-16', 'Cậu bé Kevin tinh nghịch vô tình bị gia đình bỏ lại ở nhà và phải dùng bẫy để chống lại hai tên trộm ngốc nghếch.', 'https://motchillk.bot/storage/hinh-anh/o-nha-mot-minh-thumb.jpg'),
('Mr. Bean', 'Hài hước, Vui nhộn', 90, '1997-08-01', 'Chuyến đi đầy thảm họa và tiếng cười của ngài Bean khi ông được giao nhiệm vụ hộ tống một bức tranh vô giá.', 'https://upload.wikimedia.org/wikipedia/en/3/37/Bean_movie_poster.jpg'),
('Rush Hour', 'Hành động, Hài hước', 98, '1998-09-18', 'Sự kết hợp dở khóc dở cười giữa một thanh tra gương mẫu ở Hong Kong và một viên cảnh sát mồm mép ở Los Angeles.', 'https://motchilll.now/wp-content/uploads/2024/12/gio-cao-diem-8987-thumb.webp'),
('Jumanji', 'Hài hước, Phiêu lưu', 119, '1995-12-15', 'Một trò chơi cờ ma thuật biến những điều khủng khiếp và hoang dã nhất trong rừng rậm thành sự thật.', 'https://iguov8nhvyobj.vcdn.cloud/media/catalog/product/cache/1/image/c5f0a1eff4c394a251036189ccddaacd/t/r/tr_ch_i_k_o_th_ng_c_p_2.jpg'),
('The Mask', 'Hài hước, Viễn tưởng', 101, '1994-07-29', 'Một chiếc mặt nạ gỗ bí ẩn biến anh chàng nhân viên ngân hàng nhút nhát thành một siêu anh hùng điên rồ và quậy phá.', 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQiR8_9_An2NlR4qpZE_eSXf0AMYLVX7G9gzRDRqWoyq8axhIhA');

INSERT INTO DanhGia (Ma_Phim, Ten_Nguoi_Dung, Noi_Dung) VALUES 
(1, 'Tuấn Hành Động', 'Phim xem đã mắt thực sự, kỹ xảo quá đỉnh! 10/10'),
(1, 'Bé Bi', 'Kong đấm nhau với Godzilla nhìn sợ quá nhưng mà hay.'),
(2, 'Lê Văn Bom Tấn', 'Tôi yêu bạn 3000. Phim quá cảm xúc, xứng đáng là bom tấn thế kỷ!'),
(26, 'Mẹ Bỉm', 'Phim Mai khóc hết nước mắt, Trấn Thành làm phim càng ngày càng chạm tới cảm xúc người xem.'),
(26, 'Hoàng Lệ Rơi', 'Xem xong suy nghĩ rất nhiều về cuộc sống và tình yêu. Một bộ phim quá xuất sắc!');

